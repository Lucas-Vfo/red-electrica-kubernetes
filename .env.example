# =============================================================================
# .env.example  —  variables para docker-compose
# En el clúster estos valores van
# como Secret de Kubernetes (k8s/qa/config.yaml), NO como .env.
# =============================================================================

# --- PostgreSQL (las 3 DB comparten credencial; el AISLAMIENTO es por
#     instancia y base de datos separada, no por usuario) ---
POSTGRES_USER=smartgrid
POSTGRES_PASSWORD=smartgrid_local_2026

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=smartgrid
RABBITMQ_DEFAULT_PASS=smartgrid_local_2026
